# Copy this file to .env and fill in real values. .env is gitignored.
# docker compose reads these automatically (see docker-compose.yml).

# App login credentials
APP_USERNAME=
APP_PASSWORD=
# Flask session-signing key — use a long random string (e.g. `openssl rand -hex 32`)
APP_SECRET_KEY=

# PostgreSQL password (DB_HOST/PORT/NAME/USER default in docker-compose.yml)
DB_PASSWORD=
